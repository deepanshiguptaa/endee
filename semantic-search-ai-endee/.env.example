# Endee server (default: localhost:8080)
ENDEE_URL=http://localhost:8080

# Optional: Endee auth token if you set NDD_AUTH_TOKEN
# ENDEE_AUTH_TOKEN=your_token

# Optional: OpenAI for RAG answers (leave empty to skip RAG and only do semantic search)
# OPENAI_API_KEY=sk-...

# Optional: Min similarity (0-1) to filter results; 0 = no filter
# MIN_SIMILARITY=0
